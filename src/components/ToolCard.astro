---
interface Props { name: string; slug: string; category: string; icon: string; description: string; }
const { name, slug, category, icon, description } = Astro.props;
---
<a href={`/${slug}`} class="group rounded-2xl border border-slate-200 bg-white p-6 transition hover:-translate-y-1 hover:border-indigo-200 hover:shadow-xl hover:shadow-indigo-950/5">
  <div class="flex items-center justify-between gap-4"><span class="grid size-11 place-items-center rounded-xl bg-slate-100 text-xl">{icon}</span><span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-bold text-indigo-700">{category}</span></div>
  <h3 class="mt-5 text-lg font-bold text-slate-950 group-hover:text-indigo-600">{name}</h3><p class="mt-2 text-sm leading-6 text-slate-600">{description}</p><span class="mt-5 inline-flex items-center gap-2 text-sm font-bold text-indigo-600">Abrir herramienta →</span>
</a>
