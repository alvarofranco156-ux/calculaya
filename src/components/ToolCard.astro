---
interface Props { name: string; slug: string; category: string; icon: string; description: string; featured?: boolean; }
const { name, slug, category, icon, description, featured = false } = Astro.props;
---
<a href={`/${slug}`} class:list={["tool-card", featured && "tool-card-featured"]}>
  <div class="tool-card-top"><span class="tool-icon" aria-hidden="true">{icon}</span><span class="category-pill">{category}</span></div>
  <div class="tool-card-copy"><h3>{name}</h3><p>{description}</p></div>
  <span class="tool-link">Abrir herramienta <span class="round-arrow" aria-hidden="true">→</span></span>
</a>
