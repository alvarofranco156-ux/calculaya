---
interface Props { name: string; slug: string; icon: string; description: string; count?: number; }
const { name, slug, icon, description, count } = Astro.props;
---
<a href={`/herramientas?categoria=${slug}`} class={`category-card category-${slug}`}>
  <span class="category-glow" aria-hidden="true"></span>
  <span class="category-icon" aria-hidden="true">{icon}</span>
  <div class="category-copy"><span class="card-meta">{typeof count === "number" ? `${count} herramientas` : "Explorar"}</span><h3>{name}</h3><p>{description}</p></div>
  <span class="card-arrow" aria-hidden="true">→</span>
</a>
