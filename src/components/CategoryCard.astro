---
interface Props { name: string; slug: string; icon: string; description: string; }
const { name, slug, icon, description } = Astro.props;
---
<a href={`/categoria/${slug}`} class="group rounded-2xl border border-slate-200 bg-white p-6 transition hover:-translate-y-1 hover:border-indigo-200 hover:shadow-xl hover:shadow-indigo-950/5">
  <div class="flex items-start gap-4"><span class="grid size-12 shrink-0 place-items-center rounded-2xl bg-indigo-50 text-2xl">{icon}</span><div><h3 class="font-bold text-slate-950 group-hover:text-indigo-600">{name}</h3><p class="mt-2 text-sm leading-6 text-slate-600">{description}</p></div></div>
</a>
