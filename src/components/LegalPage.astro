---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "./Breadcrumbs.astro";
const { title, description, updated = "21 de julio de 2026" } = Astro.props;
---
<BaseLayout title={`${title} | Calculaya`} description={description} canonical={Astro.url.pathname}>
  <section class="legal-hero"><div class="site-container"><Breadcrumbs items={[{label:"Inicio",href:"/"},{label:title}]} /><p class="eyebrow">Información y transparencia</p><h1>{title}</h1><p>{description}</p><small>Última actualización: {updated}</small></div></section>
  <article class="site-container legal-content"><slot /></article>
</BaseLayout>
