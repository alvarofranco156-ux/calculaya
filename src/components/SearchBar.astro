<form id="buscar" class="mx-auto mt-9 flex max-w-2xl flex-col gap-3 rounded-2xl bg-white p-3 shadow-xl shadow-indigo-950/10 sm:flex-row" action="/buscar" method="get">
  <label class="sr-only" for="q">Buscar una herramienta</label>
  <input id="q" name="q" type="search" placeholder="Ej.: IVA, hipoteca, porcentaje..." class="min-h-12 flex-1 rounded-xl border border-slate-200 px-4 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100" />
  <button type="submit" class="min-h-12 rounded-xl bg-indigo-600 px-6 font-bold text-white transition hover:bg-indigo-700">Buscar</button>
</form>
