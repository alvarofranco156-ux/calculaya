---
import { tools } from "../data/tools";
interface Props { compact?: boolean; }
const { compact = false } = Astro.props;
const searchData = tools.map(({ name, slug, category, icon, description }) => ({ name, slug, category, icon, description }));
---
<div class:list={["smart-search", compact && "smart-search-compact"]} data-search-root>
  <form class="smart-search-form" action="/buscar" method="get" autocomplete="off">
    <span class="search-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none"><path d="m21 21-4.35-4.35m2.1-5.4a7.5 7.5 0 1 1-15 0 7.5 7.5 0 0 1 15 0Z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </span>
    <label class="sr-only" for={compact ? "q-compact" : "q-home"}>Buscar una herramienta</label>
    <input id={compact ? "q-compact" : "q-home"} name="q" type="search" placeholder="Busca IVA, hipoteca, IMC, porcentajes..." data-search-input />
    <kbd>⌘ K</kbd>
    <button type="submit">Buscar</button>
  </form>
  <div class="search-suggestions" data-search-results hidden></div>
</div>

<script define:vars={{ searchData }}>
  document.querySelectorAll('[data-search-root]').forEach((root) => {
    if (root.dataset.ready === 'true') return;
    root.dataset.ready = 'true';
    const input = root.querySelector('[data-search-input]');
    const panel = root.querySelector('[data-search-results]');
    const normalize = (value) => value.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
    const hide = () => { panel.hidden = true; panel.innerHTML = ''; };
    const render = () => {
      const term = normalize(input.value.trim());
      if (term.length < 2) return hide();
      const matches = searchData.filter((tool) => normalize(`${tool.name} ${tool.category} ${tool.description}`).includes(term)).slice(0, 6);
      panel.innerHTML = matches.length
        ? matches.map((tool) => `<a href="/${tool.slug}" class="suggestion-item"><span class="suggestion-icon">${tool.icon}</span><span><strong>${tool.name}</strong><small>${tool.category}</small></span><span class="suggestion-arrow">→</span></a>`).join('')
        : `<div class="suggestion-empty">No encontramos herramientas con “${input.value.replace(/[<>]/g, '')}”.</div>`;
      panel.hidden = false;
    };
    input.addEventListener('input', render);
    input.addEventListener('focus', render);
    document.addEventListener('click', (event) => { if (!root.contains(event.target)) hide(); });
    document.addEventListener('keydown', (event) => {
      if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') { event.preventDefault(); input.focus(); }
      if (event.key === 'Escape') hide();
    });
  });
</script>
