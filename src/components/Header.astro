---
const pathname = Astro.url.pathname;
const links = [
  { href: "/categorias", label: "Categorías" },
  { href: "/populares", label: "Populares" },
  { href: "/herramientas", label: "Herramientas" },
  { href: "/mis-herramientas", label: "Mis herramientas" },
];
---
<header class="site-header">
  <div class="site-container header-inner">
    <a href="/" class="brand" aria-label="Ir al inicio de Calculaya">
      <span class="brand-mark" aria-hidden="true"><span>∑</span></span>
      <span class="brand-copy"><strong>Calculaya</strong><small>Calcula fácil</small></span>
    </a>
    <nav class="desktop-nav" aria-label="Navegación principal">
      {links.map(link => <a href={link.href} aria-current={pathname === link.href || pathname.startsWith(`${link.href}/`) ? "page" : undefined}>{link.label}</a>)}
    </nav>
    <a href="/buscar" class="header-search"><span aria-hidden="true">⌕</span> Buscar <kbd>⌘K</kbd></a>
    <details class="mobile-menu">
      <summary aria-label="Abrir menú"><span></span><span></span><span></span></summary>
      <nav aria-label="Navegación móvil">
        {links.map(link => <a href={link.href}>{link.label}</a>)}
        <a href="/buscar">Buscar herramienta</a>
      </nav>
    </details>
  </div>
</header>
