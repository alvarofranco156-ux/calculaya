---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ToolCard from "../../components/ToolCard.astro";
import { tools } from "../../data/tools";
---
<BaseLayout title={`${tools.length} herramientas online gratuitas | Calculaya`} description="Calculadoras, conversores y utilidades online gratuitas.">
  <section class="page-hero"><div class="site-container"><Breadcrumbs items={[{label:"Inicio",href:"/"},{label:"Herramientas"}]} /><p class="eyebrow">Directorio completo</p><h1>Todas las herramientas</h1><p>Utiliza {tools.length} herramientas gratuitas desde cualquier dispositivo.</p></div></section>
  <section class="page-section"><div class="site-container"><div class="tool-grid">{tools.map(tool => <ToolCard {...tool} />)}</div></div></section>
</BaseLayout>
