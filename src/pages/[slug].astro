---
import BaseLayout from "../layouts/BaseLayout.astro";
import ToolCalculator from "../components/ToolCalculator.astro";
import ToolCard from "../components/ToolCard.astro";
import { tools } from "../data/tools";
export function getStaticPaths(){return tools.map(tool=>({params:{slug:tool.slug},props:{tool}}))}
const {tool}=Astro.props;
const related=tools.filter(t=>t.category===tool.category&&t.slug!==tool.slug).slice(0,3);
const schema={"@context":"https://schema.org","@type":"WebApplication",name:tool.name,description:tool.description,applicationCategory:"UtilitiesApplication",offers:{"@type":"Offer",price:"0",priceCurrency:"EUR"}};
const faq={"@context":"https://schema.org","@type":"FAQPage",mainEntity:tool.faqs.map(f=>({"@type":"Question",name:f.question,acceptedAnswer:{"@type":"Answer",text:f.answer}}))};
---
<BaseLayout title={`${tool.name} online gratis | Calculaya`} description={tool.description} canonical={`/${tool.slug}`}>
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
<script type="application/ld+json" set:html={JSON.stringify(faq)} />
<section class="bg-gradient-to-b from-indigo-50 to-white">
<div class="mx-auto max-w-5xl px-5 py-14">
<p class="text-sm text-slate-500"><a href="/">Inicio</a> / {tool.category} / {tool.name}</p>
<div class="mt-8 grid gap-10 lg:grid-cols-[1fr_420px]">
<div><span class="text-5xl">{tool.icon}</span><h1 class="mt-5 text-4xl font-black text-slate-950">{tool.name}</h1><p class="mt-5 text-lg leading-8 text-slate-600">{tool.description}</p><div class="mt-7 rounded-2xl border border-indigo-100 bg-white p-5"><b>Fórmula o método</b><p class="mt-2 text-slate-600">{tool.formula}</p></div></div>
<ToolCalculator kind={tool.kind}/>
</div></div></section>
<article class="mx-auto max-w-5xl px-5 py-14">
<h2 class="text-3xl font-black text-slate-950">Cómo utilizarla</h2>
<ol class="mt-5 list-decimal space-y-3 pl-6 text-slate-600"><li>Introduce los valores.</li><li>Pulsa Calcular.</li><li>Revisa el resultado.</li></ol>
<h2 class="mt-12 text-3xl font-black text-slate-950">Preguntas frecuentes</h2>
<div class="mt-6 space-y-4">{tool.faqs.map(f=><details class="rounded-2xl border border-slate-200 p-5"><summary class="font-bold">{f.question}</summary><p class="mt-3 text-slate-600">{f.answer}</p></details>)}</div>
{related.length>0&&<><h2 class="mt-14 text-3xl font-black text-slate-950">Relacionadas</h2><div class="mt-7 grid gap-5 md:grid-cols-3">{related.map(t=><ToolCard {...t}/>)}</div></>}
</article>
</BaseLayout>
