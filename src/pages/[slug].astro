---
import BaseLayout from "../layouts/BaseLayout.astro";
import ToolCalculator from "../components/ToolCalculator.astro";
import ToolCard from "../components/ToolCard.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { tools } from "../data/tools";
import { getToolContent } from "../data/toolContent";

export function getStaticPaths(){return tools.map(tool=>({params:{slug:tool.slug},props:{tool}}))}
const {tool}=Astro.props;
const content=getToolContent(tool);
const related=tools.filter(t=>t.category===tool.category&&t.slug!==tool.slug).slice(0,3);
const pageUrl=`https://calculaya.es/${tool.slug}`;
const schema={
  "@context":"https://schema.org",
  "@type":"WebApplication",
  name:tool.name,
  url:pageUrl,
  description:content.metaDescription,
  applicationCategory:"UtilitiesApplication",
  operatingSystem:"Cualquier sistema con navegador web",
  browserRequirements:"JavaScript habilitado",
  isAccessibleForFree:true,
  inLanguage:"es-ES",
  offers:{"@type":"Offer",price:"0",priceCurrency:"EUR"},
  featureList:["Cálculo online inmediato","Sin registro","Resultado explicado","Uso gratuito"]
};
const faq={"@context":"https://schema.org","@type":"FAQPage",mainEntity:tool.faqs.map(f=>({"@type":"Question",name:f.question,acceptedAnswer:{"@type":"Answer",text:f.answer}}))};
---
<BaseLayout title={`${tool.name} online gratis | Calculaya`} description={content.metaDescription} canonical={`/${tool.slug}`}>
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
<script type="application/ld+json" set:html={JSON.stringify(faq)} />
<section class="tool-hero">
  <div class="site-container tool-hero-inner">
    <Breadcrumbs items={[{label:"Inicio",href:"/"},{label:"Herramientas",href:"/herramientas"},{label:tool.name}]} />
    <div class="tool-layout">
      <div class="tool-intro">
        <span class="tool-main-icon" aria-hidden="true">{tool.icon}</span>
        <p class="eyebrow">Herramienta de {tool.category}</p>
        <h1>{tool.name}</h1>
        <p class="tool-lead">Utiliza esta herramienta para {content.purpose}. Es gratuita, funciona directamente en tu navegador y no requiere registro.</p>
        <ul class="tool-benefits" aria-label="Ventajas de la herramienta">
          <li>Resultado inmediato</li><li>Datos procesados en tu navegador</li><li>Explicación sencilla</li>
        </ul>
      </div>
      <ToolCalculator kind={tool.kind} toolName={tool.name}/>
    </div>
  </div>
</section>

<article class="site-container tool-content">
  <section class="content-block content-highlight">
    <p class="eyebrow">Qué hace esta calculadora</p>
    <h2>¿Para qué sirve {tool.name.toLowerCase()}?</h2>
    <p>Sirve para {content.purpose}. Puedes modificar los valores tantas veces como necesites para comparar escenarios y comprender cómo cambia el resultado.</p>
  </section>

  <div class="content-columns">
    <section class="content-block">
      <h2>Cuándo puede resultarte útil</h2>
      <ul class="check-list">{content.uses.map(use=><li>{use}</li>)}</ul>
    </section>
    <section class="content-block">
      <h2>Cómo utilizarla</h2>
      <ol class="numbered-list"><li>Introduce los datos solicitados y revisa las unidades.</li><li>Pulsa <strong>Calcular resultado</strong>.</li><li>Lee el resultado y su explicación.</li><li>Cambia los valores para comparar otro escenario.</li></ol>
    </section>
  </div>

  <section class="content-block formula-block">
    <div><p class="eyebrow">Método de cálculo</p><h2>Fórmula e interpretación</h2></div>
    <p class="formula-text">{tool.formula}</p>
    <p>{content.interpretation}</p>
  </section>

  <aside class="notice-box"><strong>Importante:</strong> {content.warning}</aside>

  <section class="content-block faq-section">
    <p class="eyebrow">Dudas habituales</p><h2>Preguntas frecuentes</h2>
    <div class="faq-list">{tool.faqs.map(f=><details><summary>{f.question}</summary><p>{f.answer}</p></details>)}</div>
  </section>

  {related.length>0&&<section class="related-section"><p class="eyebrow">Sigue calculando</p><h2>Herramientas relacionadas</h2><div class="tool-grid">{related.map(t=><ToolCard {...t}/>)}</div></section>}
</article>
</BaseLayout>
