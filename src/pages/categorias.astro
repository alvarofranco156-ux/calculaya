---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import CategoryCard from "../components/CategoryCard.astro";
import { categories } from "../data/site";
---
<BaseLayout title="Categorías de herramientas | Calculaya" description="Explora todas las categorías de calculadoras, conversores y herramientas gratuitas de Calculaya.">
  <section class="page-hero"><div class="site-container"><Breadcrumbs items={[{label:"Inicio",href:"/"},{label:"Categorías"}]} /><p class="eyebrow">Directorio</p><h1>Categorías</h1><p>Encuentra la herramienta adecuada organizada por temática.</p></div></section>
  <section class="page-section"><div class="site-container"><div class="category-grid">{categories.map(category => <CategoryCard {...category} />)}</div></div></section>
</BaseLayout>
