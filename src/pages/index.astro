---
import BaseLayout from "../layouts/BaseLayout.astro";
import SearchBar from "../components/SearchBar.astro";
import CategoryCard from "../components/CategoryCard.astro";
import ToolCard from "../components/ToolCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { categories, popularTools } from "../data/site";
import { tools } from "../data/tools";
---
<BaseLayout title="Calculaya — Calculadoras y herramientas online gratuitas" description="Calculadoras, conversores y herramientas gratuitas para resolver operaciones cotidianas de forma rápida y clara.">
  <section class="hero-section">
    <div class="hero-orb hero-orb-one"></div><div class="hero-orb hero-orb-two"></div>
    <div class="site-container hero-content">
      <span class="hero-badge"><span class="status-dot"></span>{tools.length} herramientas online gratuitas</span>
      <h1>La herramienta que necesitas, <span>sin complicaciones.</span></h1>
      <p>Calcula, convierte y resuelve tareas cotidianas en segundos. Sin registro, desde cualquier dispositivo.</p>
      <SearchBar />
      <div class="quick-searches"><span>Prueba:</span><a href="/calculadora-iva">IVA</a><a href="/calculadora-hipoteca">Hipoteca</a><a href="/calculadora-porcentajes">Porcentajes</a><a href="/calculadora-imc">IMC</a></div>
      <ul class="trust-list" aria-label="Ventajas"><li>Resultados instantáneos</li><li>100 % gratis</li><li>Privacidad primero</li></ul>
    </div>
    <div class="site-container hero-stats" aria-label="Datos de Calculaya">
      <div><strong>{tools.length}+</strong><span>herramientas</span></div><div><strong>{categories.length}</strong><span>categorías</span></div><div><strong>0</strong><span>registros necesarios</span></div><div><strong>24/7</strong><span>siempre disponible</span></div>
    </div>
  </section>

  <section class="page-section category-section">
    <div class="site-container">
      <SectionHeading eyebrow="Explora por tema" title="Todo lo que necesitas, bien organizado" description="Encuentra rápidamente la calculadora o conversor adecuado para cada situación." href="/categorias" />
      <div class="category-grid">{categories.map(category => <CategoryCard {...category} />)}</div>
    </div>
  </section>

  <section class="page-section section-soft popular-section">
    <div class="site-container">
      <SectionHeading eyebrow="Favoritas de los usuarios" title="Empieza por las más populares" description="Una selección de herramientas prácticas para cálculos frecuentes." href="/populares" />
      <div class="tool-grid featured-tools">{popularTools.map((tool, index) => <ToolCard {...tool} featured={index < 3} />)}</div>
    </div>
  </section>

  <section class="page-section value-section">
    <div class="site-container value-grid">
      <div class="value-intro"><p class="eyebrow">Hecho para ser sencillo</p><h2>Menos tiempo calculando.<br/>Más tiempo decidiendo.</h2><p>Calculaya reúne herramientas claras, rápidas y adaptadas a móvil para que llegues al resultado sin rodeos.</p><a class="button button-primary" href="/herramientas">Ver las {tools.length} herramientas</a></div>
      <div class="benefit-grid"><article><span>⚡</span><h3>Resultados al instante</h3><p>Introduce tus datos y obtén una respuesta clara en segundos.</p></article><article><span>🔒</span><h3>Sin cuentas ni datos</h3><p>No necesitas registrarte ni compartir información personal.</p></article><article><span>📱</span><h3>Perfecta en móvil</h3><p>Diseñada para funcionar cómodamente desde cualquier pantalla.</p></article><article><span>✨</span><h3>Explicaciones claras</h3><p>No solo muestra cifras: también te ayuda a entender el resultado.</p></article></div>
    </div>
  </section>
</BaseLayout>
